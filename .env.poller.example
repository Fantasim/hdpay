# Poller Configuration
# Copy to .env.poller and fill in values

POLLER_DB_PATH=./data/poller.sqlite
POLLER_PORT=8081
POLLER_LOG_LEVEL=info
POLLER_LOG_DIR=./logs
POLLER_NETWORK=mainnet                    # mainnet, testnet

# Global start date — ignore all on-chain transactions before this (unix timestamp)
POLLER_START_DATE=1740000000

# Dashboard auth (REQUIRED)
POLLER_ADMIN_USERNAME=admin
POLLER_ADMIN_PASSWORD=changeme            # Plaintext in .env, bcrypt-hashed in memory at startup

# ── Optional API Keys (free tier — improves reliability & throughput) ──────────
# All providers below work without keys. Keys unlock higher rate limits or extra
# provider slots, improving resilience during traffic spikes or outages.

# BTC: BlockCypher (https://www.blockcypher.com → free account)
# Adds a 4th BTC provider with 1,000 req/day. Useful as a broadcast fallback.
POLLER_BLOCKCYPHER_API_KEY=

# BSC: NodeReal MegaNode / BSCTrace (https://nodereal.io → free account, 10M CU/month)
# Replaces the deprecated BscScan API (shut down Dec 18, 2025).
# Restores 20-address batch BEP-20 balance queries and adds a reliable BSC RPC node.
POLLER_NODEREAL_API_KEY=

# SOL: Helius (https://helius.dev → free account, 1M credits/month)
# Adds a Solana-native provider at 10 req/s alongside the 4 no-key providers.
POLLER_HELIUS_API_KEY=

# SOL: Alchemy (https://www.alchemy.com → free account, 30M CU/month)
# Adds a second high-reliability Solana provider at 25 req/s.
POLLER_ALCHEMY_API_KEY=

# ── Optional overrides ─────────────────────────────────────────────────────────
POLLER_MAX_ACTIVE_WATCHES=100
POLLER_DEFAULT_WATCH_TIMEOUT_MIN=30
POLLER_TIERS_FILE=./tiers.json
